executable = run_job.sh
universe   = vanilla
+JobFlavour = "nextweek"
stream_output = True
stream_error  = True

should_transfer_files = YES
WhenToTransferOutput  = ON_EXIT
notification = never
getenv     = True

Transfer_Input_Files = .
request_cpus = 1
request_memory = 8 GB
request_disk = 50 GB

output = logs/$(Cluster)_$(Process).out
error  = logs/$(Cluster)_$(Process).err
log    = logs/$(Cluster).log

